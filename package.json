{
  "scripts": {
    "dev": "concurrently \"pnpm --filter backend dev\" \"pnpm --filter frontend dev\"",
    "dev:backend": "pnpm --filter backend dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "db:generate": "pnpm --filter backend exec prisma generate",
    "db:migrate": "pnpm --filter backend exec prisma migrate dev",
    "db:push": "pnpm --filter backend exec prisma db push",
    "db:studio": "pnpm --filter backend exec prisma studio",
    "db:seed": "pnpm --filter backend exec prisma db seed",
    "db:deploy": "pnpm --filter backend exec prisma migrate deploy",
    "db:format": "pnpm --filter backend exec prisma format",
    "db:validate": "pnpm --filter backend exec prisma validate",
    "backend": "cd chainpay-platform/backend && powershell",
    "frontend": "cd chainpay-platform/frontend && powershell"
  },
  "dependencies": {
    "concurrently": "^9.2.1"
  }
}